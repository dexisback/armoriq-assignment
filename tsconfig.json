{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@armoriq/logger": ["packages/logger/src/logger.ts"],
      "@armoriq/mcp-registry": ["packages/mcp-registry/src/registry.ts"],
      "@armoriq/policy-engine": ["packages/policy-engine/src/engine.ts"],
      "@armoriq/shared-types": ["packages/shared-types/src/*"]
    }
  },
  "include": ["apps/**/*.ts", "packages/**/*.ts", "prisma/**/*.ts", "scripts/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist"]
}
