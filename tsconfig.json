{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@armoriq/db": ["packages/db/src/index.ts"],
      "@armoriq/logger": ["packages/logger/src/index.ts"],
      "@armoriq/mcp-registry": ["packages/mcp-registry/src/index.ts"],
      "@armoriq/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@armoriq/shared-types": ["packages/shared-types/src/index.ts"]
    }
  },
  "include": ["apps/agent/src/**/*.ts", "apps/custom-mcp/src/**/*.ts", "packages/**/*.ts", "prisma/**/*.ts", "scripts/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "dist", "**/vitest.config.ts", "**/*.test.ts", "**/*.spec.ts", "coverage"]
}
